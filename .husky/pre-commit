#!/usr/bin/env sh
# Pre-commit checks: typecheck, lint, secrets scanning, db schema check

echo "▶ secrets scan..."
git diff --cached --name-only --diff-filter=A | while read -r file; do
  if [ -f "$file" ]; then
    # Check for common secret patterns in new files
    if grep -qE '(PRIVATE_KEY|API_KEY|SECRET|PASSWORD|TOKEN).*0x[a-fA-F0-9]{40,}|ghp_[a-zA-Z0-9]{36,}|sk-[a-zA-Z0-9]{20,}|AIza[0-9A-Za-z_-]{35}' "$file" 2>/dev/null; then
      echo "⚠  WARNING: $file may contain a secret (private key, API key, or token)"
      echo "   If this is intentional, add a comment with 'pragma: allowlist secret' to bypass."
    fi
  fi
done

echo "▶ typecheck (root + frontend)..."
pnpm typecheck
pnpm --filter ./src/frontend run typecheck

echo "▶ lint (frontend)..."
pnpm --filter ./src/frontend run lint

# Only run db:check when the schema or migrations have changed.
# This is fast when the snapshot is current and loud when it isn't.
if git diff --cached --name-only | grep -qE '^(drizzle\.config\.ts|src/backend/db/schema\.ts|src/backend/db/migrations/)'; then
  echo "▶ db schema check (Drizzle)..."
  pnpm db:check || {
    echo "❌ Drizzle schema drift detected. Run 'pnpm db:generate' and commit the new migration."
    exit 1
  }
fi

echo "✓ pre-commit checks passed"
