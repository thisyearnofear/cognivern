# =============================================================================
# COGNIVERN ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to /opt/cognivern/shared/.env on your server
# NEVER commit this file to git - it's in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
AGENTS_ENABLED=false  # Set to 'true' for cognivern-agents process

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
API_KEY=your_secure_api_key_here

# CORS - comma-separated list of allowed origins
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Sapience / Arbitrum (Trading)
# -----------------------------------------------------------------------------
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ETHEREAL_RPC_URL=https://ethereal-rpc.sapience.xyz
SAPIENCE_PRIVATE_KEY=0xyour_private_key_here
EAS_CONTRACT_ADDRESS=0xbD75f629A22F97C3529a9F920621305435234024

# -----------------------------------------------------------------------------
# Recall Network (Agent Memory)
# -----------------------------------------------------------------------------
RECALL_API_KEY=your_recall_api_key
RECALL_BUCKET=agent-memory
RECALL_ENDPOINT=https://api.recall.network/v1
RECALL_BUCKET_ADDRESS=0x...

# Recall Trading API
RECALL_TRADING_API_KEY=your_recall_trading_api_key
RECALL_TRADING_BASE_URL=https://api.sandbox.competitions.recall.network

# -----------------------------------------------------------------------------
# Filecoin / FVM (Governance)
# -----------------------------------------------------------------------------
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_PRIVATE_KEY=your_filecoin_private_key
GOVERNANCE_CONTRACT_ADDRESS=0x...
STORAGE_CONTRACT_ADDRESS=0x...
USDFC_TOKEN_ADDRESS=0x...

# -----------------------------------------------------------------------------
# LLM Providers (For Forecasting)
# -----------------------------------------------------------------------------
# Primary AI Provider (recommended)
FIREWORKS_API_KEY=
KILOCODE_API_KEY=

# Alternative providers (fallback)
CEREBRAS_API_KEY=
GROQ_API_KEY=
ROUTEWAY_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Optional: External APIs
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=
OPENSEA_API_KEY=
DEBANK_API_KEY=
COIN_GECKO_API_KEY=
BINANCE_API_KEY=
COIN_MARKET_CAP_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Feature Flags
# -----------------------------------------------------------------------------
CREATE_SAMPLE_POLICIES=false
DEFAULT_POLICY=standard

# Optional: MCP Server
MCP_ENABLED=false
MCP_SERVER_URL=http://localhost:3001
MCP_API_KEY=
