# =============================================================================
# COGNIVERN ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it's in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
AGENTS_ENABLED=false

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
COGNIVERN_API_KEY=your_secure_api_key_here
JWT_SECRET=your_jwt_secret_here

# CORS - comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Self-call base URL — used by internal agents (Sapience, UserTradingAgent)
# to route their own actions through Cognivern's governance pipeline. In
# dev, leave at default. In prod, set to the deployed API URL.
# -----------------------------------------------------------------------------
COGNIVERN_SELF_BASE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Human confirmation token for Sapience trades >= 10 USDe. If unset, trades
# at or above the threshold are held (no execution) and surfaced via audit.
# In production, the operator UI issues short-lived tokens per held trade.
# -----------------------------------------------------------------------------
SAPIENCE_HUMAN_CONFIRM_TOKEN=

# -----------------------------------------------------------------------------
# Filecoin / FVM (Governance + Audit Anchoring, optional)
# -----------------------------------------------------------------------------
# FILECOIN_PRIVATE_KEY is also used as a shared EVM signing key by
# AuditLogService (evidence signing) and FhenixPolicyService (fallback).
# In production, consider using dedicated keys per chain.
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_PRIVATE_KEY=

# GovernanceContract — deployed on both Filecoin Calibration and X Layer testnet.
# Set after running scripts/deploy-hardhat.cjs or scripts/deploy-contracts.ts.
GOVERNANCE_CONTRACT_ADDRESS=0x...

# AIGovernanceStorage — audit record anchoring on FVM.
# Set to enable FilecoinStorageService (dual-anchor alongside 0G).
STORAGE_CONTRACT_ADDRESS=0x...

# -----------------------------------------------------------------------------
# 0G Bridge Buildathon — 5-Component Configuration
# -----------------------------------------------------------------------------
# Cognivern is submitted to the 0G Bridge by AKINDO buildathon as the
# governance & trust layer for the 0G agent economy. Five 0G components
# are integrated; see docs/HACKATHON.md and docs/ARCHITECTURE.md#0g-bridge-buildathon-plan
# for the wave-by-wave plan and the 0G Bridge target architecture.

# --- 0G Storage (Audit Anchoring) -----------------------------------------
# Anchors audit records to 0G decentralized storage.
# Requires ZEROG_PRIVATE_KEY to enable; leave empty for log-only mode.
ZEROG_PRIVATE_KEY=
ZEROG_INDEXER_URL=https://indexer-storage-testnet-standard.0g.ai

# --- 0G Chain (EVM-compatible L1) -----------------------------------------
# RPC for the chain where GovernanceContract, GovernedVault, and the new
# AgentGovernancePolicy / AgenticIDRegistry contracts are deployed.
# Testnet (Newton) default; switch to mainnet in Wave 3 (Jul 11-24, 2026).
ZEROG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZEROG_CHAIN_CHAIN_ID=16602
# Deployed contract addresses (filled in after running deploy/0g/* scripts).
ZEROG_GOVERNANCE_CONTRACT_ADDRESS=
ZEROG_VAULT_ADDRESS=
ZEROG_AGENT_GOVERNANCE_POLICY_ADDRESS=
ZEROG_AGENTIC_ID_REGISTRY_ADDRESS=

# --- 0G Pay (Agent-to-agent settlement) -----------------------------------
# 0G Pay SDK configuration. Approved spends from OwsWalletService settle
# natively through 0G Pay; the on-chain receipt is appended to the audit
# record. Set ZEROG_PAY_ENABLED=true to activate.
ZEROG_PAY_ENABLED=false
ZEROG_PAY_API_URL=
ZEROG_PAY_MERCHANT_ID=
ZEROG_PAY_API_KEY=

# --- Agentic ID (ERC-7857) ------------------------------------------------
# Each governed agent is tokenized as an Agentic ID carrying its
# intelligence, audit history, and active policy as encrypted metadata.
# Backed by AgenticIDRegistry contract (ZEROG_AGENTIC_ID_REGISTRY_ADDRESS above).
AGENTIC_ID_ENABLED=false
# Optional: separate signer key for Agentic ID minting (falls back to ZEROG_PRIVATE_KEY).
AGENTIC_ID_SIGNER_KEY=

# --- 0G Compute Network (Verifiable AI Inference) -------------------------
# Routes governance-critical LLM calls (contract audit in
# ChainGPTAuditService, suspicion scoring in ControlEvaluationService) to
# the 0G Compute Network for verifiable inference. Closed-source providers
# become fallback. Set ZERO_G_COMPUTE_ENABLED=true to activate.
ZERO_G_COMPUTE_ENABLED=false
ZERO_G_COMPUTE_API_URL=https://api-compute-testnet.0g.ai
ZERO_G_COMPUTE_API_KEY=
# When true, every governance-critical LLM call MUST be served by 0G Compute
# (no fallback to closed-source providers). Use in Wave 3+ mainnet demos.
ZERO_G_COMPUTE_STRICT=false

# -----------------------------------------------------------------------------
# MongoDB Atlas — Persistent Agent Memory & Run Ledger
# -----------------------------------------------------------------------------
# Required for MongoDB-backed persistence (run ledger, agent memory).
# Create a free cluster at https://cloud.mongodb.com, then set your connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Database name (default: cognivern)
MONGODB_DB_NAME=cognivern

# -----------------------------------------------------------------------------
# HydraDB — Agent Memory & Recall (Agents Under Pressure hackathon)
# -----------------------------------------------------------------------------
# Required for persistent agent memory across sessions.
# Sign up at https://app.hydradb.com to get your API key.
HYDRA_DB_API_KEY=your_hydradb_api_key_here
# Tenant ID — create one via the HydraDB dashboard or auto-create on first use
HYDRA_TENANT_ID=cognivern-os

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
# At least one provider key is required
OPENAI_API_KEY=sk-your_openai_api_key
# Optional fallbacks
GROQ_API_KEY=
CEREBRAS_API_KEY=
ROUTEWAY_API_KEY=
FIREWORKS_API_KEY=
VENICE_API_KEY=
KILOCODE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Together AI (Governance Policy Evaluator — Agents Assemble integration)
# -----------------------------------------------------------------------------
# Required for AI-powered policy evaluation via Together AI inference
# Get your key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here
# Optional: override the default model (Llama-3.3-70B-Instruct-Turbo)
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# -----------------------------------------------------------------------------
# Sapience / Arbitrum (optional - for trading features)
# -----------------------------------------------------------------------------
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ETHEREAL_RPC_URL=https://rpc.ethereal.trade
SAPIENCE_PRIVATE_KEY=your_sapience_private_key_here
# EAS SchemaRegistry on Arbitrum One — verify on
# https://arbiscan.io/address/<address> before relying on this. The EAS team
# publishes official addresses at https://docs.attest.sh/docs/quick-start--contracts;
# if your attestation path needs the real registry, fetch it from there.
EAS_CONTRACT_ADDRESS=0xbD75f629A22F97C3529a9F920621305435234024

# -----------------------------------------------------------------------------
# Arbitrum Sepolia (Governance deployment — primary Arbitrum footprint)
# -----------------------------------------------------------------------------
# Cognivern GovernanceContract + GovernedVault, deployed to Arbitrum Sepolia
# (chain 421614). Set ARBITRUM_PRIVATE_KEY to redeploy; falls back to
# FHENIX_PRIVATE_KEY if unset.
ARBITRUM_PRIVATE_KEY=
ARBITRUM_GOVERNANCE_CONTRACT_ADDRESS=0x...
ARBITRUM_VAULT_ADDRESS=0x...
# Fhenix testnet chain ID remains 421614, but the FHE co-processor
# (TASK_MANAGER_ADDRESS) is not present on plain Arbitrum Sepolia. The
# on-chain governance path lives in ARBITRUM_GOVERNANCE_CONTRACT_ADDRESS.

# -----------------------------------------------------------------------------
# OWS Wallet (optional)
# -----------------------------------------------------------------------------
OWS_VAULT_SECRET=development-ows-vault-secret
OWS_API_KEY=
OWS_EXTERNAL_WALLET_URL=
OWS_EXTERNAL_WALLET_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# MCP Server (optional)
# -----------------------------------------------------------------------------
MCP_ENABLED=false
MCP_DEFAULT_SERVER=ows-governance
MCP_API_KEY=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Governance Defaults
# -----------------------------------------------------------------------------
DEFAULT_POLICY=standard

# -----------------------------------------------------------------------------
# Structured Alerting (optional — Slack / PagerDuty)
# -----------------------------------------------------------------------------
# When set, critical governance decisions (denied/flagged) are forwarded
# to these alert sinks alongside the existing webhook notifications.
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# -----------------------------------------------------------------------------
# Optional: External APIs
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Voice (ElevenLabs)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Optional: ChainGPT (Smart Contract Auditing)
# -----------------------------------------------------------------------------
CHAINGPT_API_KEY=

# -----------------------------------------------------------------------------
# Optional: OpenZeppelin Defender (Runtime Monitoring)
# -----------------------------------------------------------------------------
OZ_DEFENDER_API_KEY=
OZ_DEFENDER_API_SECRET=

# -----------------------------------------------------------------------------
# Mantle L2 (Agent Execution Layer)
# -----------------------------------------------------------------------------
# Required for deploying GovernedVault on Mantle — agents execute DeFi here
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=
MANTLE_VAULT_ADDRESS=0x...

# -----------------------------------------------------------------------------
# Fhenix / coFHE (Confidential Policy Evaluation)
# -----------------------------------------------------------------------------
# The coFHE plugin is `@cofhe/hardhat-plugin@0.5.2`. The live testnet services
# are at testnet-cofhe.fhenix.zone (coFHE), testnet-cofhe-vrf.fhenix.zone
# (verifier), and testnet-cofhe-tn.fhenix.zone (threshold network).
# The TaskManager proxy lives on Arbitrum Sepolia at 0xeA30c4B…7848D9
# (hardcoded in @fhenixprotocol/cofhe-contracts@0.1.3).
# ConfidentialSpendPolicy is live on Arbitrum Sepolia at
# 0xaf9F46913eFA99912c3a5069b98d4AEFB0404950.
# See docs/FHENIX_INTEGRATION.md and scripts/test-fhe-onchain.ts.
FHENIX_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
FHENIX_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
FHENIX_POLICY_CONTRACT=0x...
# The three coFHE service URLs (overridable for testnets / private infra)
FHENIX_COFHE_URL=https://testnet-cofhe.fhenix.zone
FHENIX_VERIFIER_URL=https://testnet-cofhe-vrf.fhenix.zone
FHENIX_TN_URL=https://testnet-cofhe-tn.fhenix.zone
# Falls back to ARBITRUM_PRIVATE_KEY (or FILECOIN_PRIVATE_KEY) if not set.
FHENIX_PRIVATE_KEY=
# Optional: timeout for FHE evaluation in milliseconds (default: 30000)
FHENIX_EVALUATE_TIMEOUT_MS=30000
# FHE Decision Watcher — automates the two-phase FHE resolution flow.
# When enabled, watches for Pending outcomes from evaluateSpend, polls
# the FHEOS threshold decryption endpoint, and calls resolveDecision.
FHE_WATCHER_ENABLED=false
# Poll interval for checking pending FHE decisions (default: 5000ms)
FHE_WATCHER_POLL_INTERVAL_MS=5000

# Control Evaluation Mode — parallel suspicion scoring for AI agent monitoring
# When enabled, every governance evaluation gets a suspicion score (0-1)
# stored in the audit trail. Does not change approve/deny decisions.
CONTROL_EVAL_MODE=false
# Auto-hold threshold: if set > 0, actions with suspicion composite >= this
# value are held for human review instead of auto-approved. Requires
# CONTROL_EVAL_MODE=true. Recommended: 0.8 for conservative, 0.6 for moderate.
SUSPICION_HOLD_THRESHOLD=0

# Privara / Confidential Payroll (optional — falls back to FHENIX_PRIVATE_KEY)
PRIVARA_PRIVATE_KEY=
PRIVARA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
PRIVARA_NETWORK=testnet

# -----------------------------------------------------------------------------
# Optional: Ethereum RPC (for bytecode analysis)
# -----------------------------------------------------------------------------
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key

# -----------------------------------------------------------------------------
# Canton Network (HackCanton S2 DevNet)
# -----------------------------------------------------------------------------
# JSON Ledger API v2 endpoint. Use the shared HackCanton S2 DevNet node:
# https://ledger-api-json.participant.hackcanton-01.devnet.naas.noders.services:443
CANTON_JSON_API_URL=
CANTON_LEDGER_ID=hackcanton-01
CANTON_LEDGER_USER_ID=
CANTON_APPLICATION_ID=cognivern

# Daml template IDs. Canton v2 JSON Ledger API accepts package-name references
# (#<packageName>:<module>:<entity>) for commands/queries; events still return
# full package IDs, which the client resolves automatically.
CANTON_TEMPLATE_AUCTION="#daml:Main:SealedBidAuction"
CANTON_TEMPLATE_BID="#daml:Main:Bid"
CANTON_TEMPLATE_RESULT="#daml:Main:AuctionResult"

# Authentication: obtain a Bearer token from the NODERS Keycloak password grant.
# CANTON_BEARER_TOKEN is used directly if set; otherwise the backend can fall
# back to the OIDC password grant using the values below.
CANTON_BEARER_TOKEN=
CANTON_OIDC_TOKEN_URL=https://keycloak.naas.noders.services/realms/noders-appsfactory/protocol/openid-connect/token
CANTON_OIDC_CLIENT_ID=web-app-ui-hackcanton-01-devnet
CANTON_OIDC_USERNAME=
CANTON_OIDC_PASSWORD=
CANTON_OIDC_AUDIENCE=https://hackcanton-01.devnet.naas.noders.services
CANTON_OIDC_SCOPE=openid daml_ledger_api offline_access

# Demo party names. On shared DevNet nodes the admin may suffix parties with
# the project name (e.g. auctioneer-cognivern, alice-cognivern). Set these to
# match the parties allocated on the DevNet participant.
CANTON_DEMO_MANAGER_NAME=auctioner-cognivern
CANTON_DEMO_BIDDER_NAMES=alice-cognivern,bob-cognivern,charlie-cognivern
# Static mapping of demo party names to full Canton party identifiers.
# Required on shared DevNet nodes where the authenticated user cannot list or
# allocate parties. Format: name=partyId,name=partyId,...
CANTON_DEMO_PARTY_IDS=auctioner-cognivern=auctioner-cognivern::122003aa7c491e00a453145c4d2cd3dbf5db8908b4e663c9944baed57fd66effa668,alice-cognivern=alice-cognivern::122003aa7c491e00a453145c4d2cd3dbf5db8908b4e663c9944baed57fd66effa668,bob-cognivern=bob-cognivern::122003aa7c491e00a453145c4d2cd3dbf5db8908b4e663c9944baed57fd66effa668,charlie-cognivern=charlie-cognivern::122003aa7c491e00a453145c4d2cd3dbf5db8908b4e663c9944baed57fd66effa668
