# =============================================================================
# COGNIVERN ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it's in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
AGENTS_ENABLED=false

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
COGNIVERN_API_KEY=your_secure_api_key_here

# CORS - comma-separated list of allowed origins
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Filecoin / FVM (Governance)
# -----------------------------------------------------------------------------
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_PRIVATE_KEY=your_filecoin_private_key
FILECOIN_NETWORK=calibration

# Deployed contract addresses (set after running contract deployment)
GOVERNANCE_CONTRACT_ADDRESS=0x...
STORAGE_CONTRACT_ADDRESS=0x...
USDFC_TOKEN_ADDRESS=0x7b79995e5f793A07Bc00c21412e50Ecae098E7f9

# -----------------------------------------------------------------------------
# Recall Network (Agent Memory)
# -----------------------------------------------------------------------------
RECALL_API_KEY=your_recall_api_key
RECALL_API_URL=https://api.competitions.recall.network
RECALL_SANDBOX_URL=https://api.sandbox.competitions.recall.network
RECALL_BUCKET_ALIAS=escheat-agents-bucket
RECALL_CHAIN_ID=314159
RECALL_NETWORK=calibration
RECALL_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Recall Trading API (optional)
RECALL_TRADING_API_KEY=your_recall_trading_api_key
RECALL_TRADING_BASE_URL=https://api.sandbox.competitions.recall.network

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
# At least one provider key is required
OPENAI_API_KEY=sk-your_openai_api_key
# Optional fallbacks
GROQ_API_KEY=
CEREBRAS_API_KEY=
ROUTEWAY_API_KEY=
FIREWORKS_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Sapience / Arbitrum (optional - for trading features)
# -----------------------------------------------------------------------------
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ETHEREAL_RPC_URL=https://rpc.ethereal.trade
SAPIENCE_PRIVATE_KEY=0xyour_private_key_here
EAS_CONTRACT_ADDRESS=0xbD75f629A22F97C3529a9F920621305435234024

# -----------------------------------------------------------------------------
# OWS Wallet (optional)
# -----------------------------------------------------------------------------
OWS_VAULT_SECRET=development-ows-vault-secret
OWS_API_KEY=
OWS_EXTERNAL_WALLET_URL=
OWS_EXTERNAL_WALLET_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# MCP Server (optional)
# -----------------------------------------------------------------------------
MCP_ENABLED=false
MCP_DEFAULT_SERVER=ows-governance
MCP_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare Workers (optional)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKER_URL=http://localhost:8787
CLOUDFLARE_WORKER_ENABLED=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Governance Defaults
# -----------------------------------------------------------------------------
DEFAULT_POLICY=standard
AUDIT_FREQUENCY=daily

# -----------------------------------------------------------------------------
# Optional: External APIs
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=
OPENSEA_API_KEY=
DEBANK_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Voice (ElevenLabs)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Optional: ChainGPT (Smart Contract Auditing)
# -----------------------------------------------------------------------------
CHAINGPT_API_KEY=
