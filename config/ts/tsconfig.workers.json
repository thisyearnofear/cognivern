{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "../../dist/workers",
    "rootDir": "../../src/modules/cloudflare-agents",
    "skipLibCheck": true,
    "declaration": false,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "../../src/modules/cloudflare-agents/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
