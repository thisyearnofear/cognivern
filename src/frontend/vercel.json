{
  "env": {
    "VITE_API_KEY": "",
    "VITE_BACKEND_URL": "https://api.thisyearnofear.com",
    "VITE_API_BASE_URL": "/api"
  },
  "build": {
    "env": {
      "VITE_API_KEY": "",
      "VITE_BACKEND_URL": "https://api.thisyearnofear.com",
      "VITE_API_BASE_URL": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/(api|health|metrics|projects|audit|cre|dashboard/bundle|ingest|system/health|market|governance|recall|sapience|external-agents|mcp|simulation)(.*)",
      "destination": "https://api.thisyearnofear.com/$1$2"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
